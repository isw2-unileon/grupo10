# Database
DB_USER=user
DB_PASSWORD=password
DB_NAME=learning_platform
DB_PORT_HOST=5432

# Server
SERVER_PORT_HOST=8080

# Frontend
FRONTEND_PORT_HOST=5173

# Auth — change this to a long random string in any real environment
JWT_SECRET=dev-insecure-secret

# AI — Groq API key for the notes AI review feature ("Consultar IA").
# Get a free key at https://console.groq.com/keys. Leave empty to disable AI review.
GROQ_API_KEY=

# Testing — connection string used ONLY by the Postgres integration tests
# (the ones tagged `integration`). Optional: leave it unset and those tests
# skip themselves; the normal `go test ./...` run never needs it. CI provides
# its own Postgres, so you don't need this for pull requests either.
#
# NOTE: `go test` does NOT read this file automatically — export the variable
# (or pass it inline) when running the integration tests:
#   export TEST_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable"
#   go test -tags integration ./backend/internal/notes/
#
# WARNING: the integration tests TRUNCATE tables, so point this at a DISPOSABLE
# Postgres (e.g. a throwaway container), never at your real dev database.
TEST_DATABASE_URL=
